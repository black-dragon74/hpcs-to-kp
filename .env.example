# Log level: DEBUG, INFO, WARN, ERROR, FATAL
#LOG_LEVEL=INFO

# Kubernetes namespace where ODF is installed (default: openshift-storage)
#NS=openshift-storage

#============================================================#
# migrate-csi.sh settings                                    #
#============================================================#

# JSON output file tracking volume state across phases (default: rbd_volumes.json)
#DATA_FILE=rbd_volumes.json

# StorageClass used by encrypted RBD volumes (default: ocs-storagecluster-ceph-rbd-encrypted)
# Pool, pool ID, cluster ID, and volume name prefix are derived automatically from this.
#STORAGE_CLASS=ocs-storagecluster-ceph-rbd-encrypted

#============================================================#
# migrate-osd.sh settings                                    #
#============================================================#

# JSON tracking file for OSD keys (default: osd_keys.json)
#DATA_FILE=osd_keys.json

# Directory for exported OSD key files (default: exported_keys)
#EXPORTED_DIR=exported_keys

# CephCluster CR name (default: ocs-storagecluster-cephcluster)
#CEPH_CLUSTER_NAME=ocs-storagecluster-cephcluster

# OCS KMS connection details ConfigMap (default: ocs-kms-connection-details)
#KMS_CONFIGMAP_NAME=ocs-kms-connection-details

# Token secret name — auto-detected from CephCluster CR if not set
#TOKEN_SECRET_NAME=

#============================================================#
# Shared KMS credentials (used by both scripts)              #
#============================================================#

# --- HPCS (source KMS) ---
# For migrate-csi.sh: used in phase2 to unwrap DEKs via HPCS root key.
# For migrate-osd.sh: used in phase1-2 to list and export Standard Keys.
#   HPCS_KEY_ID is only needed for migrate-csi.sh (root key for unwrap).
#   HPCS_INSTANCE_ID, HPCS_IAM_API_KEY, and HPCS_URL can be auto-detected
#   from the CephCluster CR and token secret by migrate-osd.sh.
HPCS_INSTANCE_ID=
HPCS_IAM_API_KEY=
HPCS_KEY_ID=
HPCS_URL=

# --- Key Protect (destination KMS) ---
# For migrate-csi.sh: used in phase3 to re-wrap DEKs with the new KP root key.
# For migrate-osd.sh: used in phase3-5 to import keys and update K8s resources.
#   KP_KEY_ID is only needed for migrate-csi.sh (root key for wrap).
KP_INSTANCE_ID=
KP_IAM_API_KEY=
KP_KEY_ID=
KP_URL=
